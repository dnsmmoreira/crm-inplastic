{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://klbkkertbwuusegtdgkw.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "inplastic-crm-mcp",
      "version": "0.1.0",
      "title": "INPLASTIC CRM"
    },
    "tools": [
      {
        "name": "list_leads",
        "title": "Listar leads",
        "description": "Lista leads visíveis para o usuário autenticado no CRM INPLASTIC (admin vê tudo; vendedor vê os próprios). Retorna nome do contato, empresa, estágio, vendedor, valor estimado, criação, último contato, mudança de etapa e dias sem contato. Filtros: estágio e limite.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "stage": {
              "type": "string",
              "enum": [
                "atendimento",
                "novo",
                "qualificacao",
                "proposta",
                "negociacao",
                "ganho",
                "perdido"
              ],
              "description": "Filtrar por estágio do pipeline"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "description": "Máximo de resultados (padrão 50)"
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_tasks",
        "title": "Listar tarefas",
        "description": "Lista tarefas do CRM visíveis ao usuário autenticado (admin vê todas; vendedor vê as próprias). Retorna título, tipo, prioridade, status, vendedor, lead/cliente vinculado, data prevista e escalonamentos.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pendente",
                "concluida",
                "adiada"
              ]
            },
            "tipo": {
              "type": "string",
              "description": "Filtrar por tipo (ex: follow_up, cadencia_proposta, pos_venda_*)"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "pipeline_stats",
        "title": "Estatísticas do pipeline",
        "description": "Retorna, para o usuário autenticado, a contagem de leads e o valor estimado por estágio do pipeline, além dos totais gerais.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
